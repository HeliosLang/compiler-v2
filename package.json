{
  "name": "@helios-lang/compiler-v2",
  "version": "0.1.0",
  "description": "Rewrite of the helios compiler",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "rollup -c ./rollup.config.js",
    "lint": "eslint",
    "prettify": "prettier . --write",
    "test": "pnpm run test:types && pnpm run test:unit && pnpm run test:integ",
    "test:integ": "pnpm -C ./test run test",
    "test:types": "pnpm tsc --noEmit",
    "test:unit": "bun test"
  },
  "prettier": {
    "trailingComma": "none",
    "tabWidth": 2,
    "semi": false,
    "singleQuote": false
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/bun": "^1.3.10",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "rollup": "^4.60.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
